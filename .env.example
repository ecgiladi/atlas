# --- Atlas environment ---
# Copy to .env and fill in. Never commit .env.

# Postgres (container-internal port stays 5432; host-mapped to 5434)
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://atlas:devpassword@localhost:5434/atlas

# Redis (host-mapped to 6380)
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@localhost:6380

# Claude / Anthropic — MICRO extraction pipeline (added in a later session)
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-sonnet-4-6

# App
DEBUG=false
COOKIE_SECURE=true
CORS_ORIGINS=["https://atlas.giladihome.info"]
